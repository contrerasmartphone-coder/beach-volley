{
  "entities": {
    "Team": {
      "title": "Team",
      "description": "Represents a beach volley team",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "player1": { "type": "string" },
        "player2": { "type": "string" },
        "level": {
          "type": "string",
          "enum": ["Beginner", "Bronze", "Silver", "Gold"]
        },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "phone2": { "type": "string" },
        "email2": { "type": "string" },
        "registeredAt": { "type": "string" },
        "group": { "type": "string" },
        "wins": { "type": "number" },
        "losses": { "type": "number" },
        "setsWon": { "type": "number" },
        "setsLost": { "type": "number" },
        "pointsWon": { "type": "number" },
        "pointsLost": { "type": "number" },
        "points": { "type": "number" }
      },
      "required": ["id", "name", "player1", "player2", "level", "phone", "email", "registeredAt"]
    },
    "Match": {
      "title": "Match",
      "description": "Represents a tournament match",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "round": { "type": "number" },
        "roundLabel": { "type": "string" },
        "position": { "type": "number" },
        "team1": { "type": "object" },
        "team2": { "type": "object" },
        "team1Score": { "type": "number" },
        "team2Score": { "type": "number" },
        "sets": { "type": "array" },
        "status": {
          "type": "string",
          "enum": ["scheduled", "live", "completed"]
        },
        "court": { "type": "string" },
        "time": { "type": "string" },
        "winnerId": { "type": "string" },
        "nextMatchId": { "type": "string" },
        "nextMatchSlot": { "type": "string", "enum": ["team1", "team2"] },
        "loserMatchId": { "type": "string" },
        "loserMatchSlot": { "type": "string", "enum": ["team1", "team2"] },
        "livePointTicker": { "type": "string" },
        "phase": { "type": "string" },
        "groupName": { "type": "string" },
        "pointsPerSet": { "type": "number" },
        "maxSets": { "type": "number" }
      },
      "required": ["id", "round", "roundLabel", "position", "team1Score", "team2Score", "sets", "status", "court", "time"]
    },
    "NotificationLog": {
      "title": "NotificationLog",
      "description": "A notification representing a score update or scheduling change",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "time": { "type": "string" },
        "type": { "type": "string", "enum": ["live_update", "schedule_change", "system", "result"] },
        "matchId": { "type": "string" }
      },
      "required": ["id", "title", "message", "time", "type"]
    },
    "TournamentConfig": {
      "title": "TournamentConfig",
      "description": "Represents the active configuration settings of the beach volleyball tournament",
      "type": "object",
      "properties": {
        "admittedTeamsCount": { "type": "number" },
        "activeTournamentConfig": { "type": "object" },
        "tournamentDate": { "type": "string" },
        "tournamentGender": { "type": "string", "enum": ["maschile", "misto", "femminile", ""] }
      }
    },
    "AppUser": {
      "title": "AppUser",
      "description": "Represents an access-authorized user of the Beach Volley Hub application",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "collaborator", "reader", "ATLETA"] },
        "createdAt": { "type": "string" },
        "nome": { "type": "string" },
        "cognome": { "type": "string" },
        "telefono": { "type": "string" },
        "dataNascita": { "type": "string" },
        "activeSessionId": { "type": "string" },
        "lastActiveAt": { "type": "number" }
      },
      "required": ["id", "username", "password", "role", "createdAt"]
    },
    "RegistrationRequest": {
      "title": "RegistrationRequest",
      "description": "Represents a pending registration request from an operator",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "collaborator", "reader", "ATLETA"] },
        "createdAt": { "type": "string" },
        "nome": { "type": "string" },
        "cognome": { "type": "string" },
        "telefono": { "type": "string" },
        "dataNascita": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["id", "username", "password", "role", "createdAt", "nome", "cognome", "telefono", "status"]
    },
    "ArchivedTournament": {
      "title": "ArchivedTournament",
      "description": "Represents a completed and saved beach volleyball tournament",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "date": { "type": "string" },
        "formula": { "type": "string" },
        "teamsCount": { "type": "number" },
        "teams": { "type": "array" },
        "winnerTeamName": { "type": "string" },
        "podium": { "type": "object" }
      },
      "required": ["id", "name", "date", "formula", "teamsCount", "teams"]
    },
    "ActiveTournamentSave": {
      "title": "ActiveTournamentSave",
      "description": "Represents a backup of an in-progress active tournament",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "date": { "type": "string" },
        "formula": { "type": "string" },
        "teamsCount": { "type": "number" },
        "teams": { "type": "array" },
        "matches": { "type": "array" },
        "activeTournamentConfig": { "type": "object" },
        "admittedTeamsCount": { "type": "number" }
      },
      "required": ["id", "name", "date", "formula", "teamsCount", "teams", "matches"]
    },
    "SystemStatus": {
      "title": "SystemStatus",
      "description": "Defines global online/offline connection state",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["online", "offline"] }
      },
      "required": ["status"]
    }
  },
  "firestore": {
    "/config/status": {
      "schema": "SystemStatus",
      "description": "Stores the global connection status (Online/Offline) for non-admin users"
    },
    "/teams/{teamId}": {
      "schema": "Team",
      "description": "Stores teams registered for the tournament"
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Stores volleyball matches generated or schedule status"
    },
    "/notifications/{notificationId}": {
      "schema": "NotificationLog",
      "description": "Stores system notification logs and news"
    },
    "/config/settings": {
      "schema": "TournamentConfig",
      "description": "Houses current tournament phase constraints and settings variables"
    },
    "/users/{userId}": {
      "schema": "AppUser",
      "description": "Stores credentials and permissions for users running the app"
    },
    "/registrationRequests/{requestId}": {
      "schema": "RegistrationRequest",
      "description": "Stores pending registration requests from operators awaiting admin approval"
    },
    "/archives/{archiveId}": {
      "schema": "ArchivedTournament",
      "description": "Stores historical tournament results for export, lookup, and printing"
    },
    "/saves/{saveId}": {
      "schema": "ActiveTournamentSave",
      "description": "Stores backups of active tournaments currently in-progress"
    }
  }
}
