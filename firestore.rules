rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_+%@. \'àèéìòùÀÈÉÌÒÙáéíóúÁÉÍÓÚäöüÄÖÜñÑ-]+$');
    }
    
    function isValidTeam(t) {
      return t.id is string
        && t.name is string && t.name.size() <= 200
        && t.player1 is string && t.player1.size() <= 200
        && t.player2 is string && t.player2.size() <= 200
        && (t.level == 'Beginner' || t.level == 'Bronze' || t.level == 'Silver' || t.level == 'Gold')
        && t.phone is string && t.phone.size() <= 50;
    }

    function isValidMatch(m) {
      return m.id is string
        && m.round is int
        && m.roundLabel is string
        && m.position is int
        && m.team1Score is int
        && m.team2Score is int
        && (m.status == 'scheduled' || m.status == 'live' || m.status == 'completed')
        && m.court is string
        && m.time is string;
    }

    function isValidNotification(n) {
      return n.id is string
        && n.title is string && n.title.size() <= 300
        && n.message is string && n.message.size() <= 2000
        && n.time is string
        && (n.type == 'live_update' || n.type == 'schedule_change' || n.type == 'system' || n.type == 'result');
    }

    function isValidUser(u) {
      return u.id is string
        && u.username is string && u.username.size() <= 200
        && u.password is string && u.password.size() <= 200
        && (u.role == 'admin' || u.role == 'collaborator' || u.role == 'reader' || u.role == 'ATLETA')
        && u.createdAt is string
        && (!('nome' in u) || u.nome is string)
        && (!('cognome' in u) || u.cognome is string)
        && (!('telefono' in u) || u.telefono is string)
        && (!('dataNascita' in u) || u.dataNascita is string)
        && (!('genere' in u) || u.genere == 'M' || u.genere == 'F')
        && (!('activeSessionId' in u) || u.activeSessionId is string)
        && (!('lastActiveAt' in u) || u.lastActiveAt is int || u.lastActiveAt is float)
        && (!('isTesseratoWsicily' in u) || u.isTesseratoWsicily is bool);
    }

    function isValidRegistrationRequest(r) {
      return r.id is string
        && r.username is string && r.username.size() <= 200
        && r.password is string && r.password.size() <= 200
        && (r.role == 'admin' || r.role == 'collaborator' || r.role == 'reader' || r.role == 'ATLETA')
        && r.createdAt is string
        && r.nome is string && r.nome.size() <= 200
        && r.cognome is string && r.cognome.size() <= 200
        && r.telefono is string && r.telefono.size() <= 50
        && (r.status == 'pending' || r.status == 'approved' || r.status == 'rejected')
        && (!('genere' in r) || r.genere == 'M' || r.genere == 'F')
        && (!('dataNascita' in r) || r.dataNascita is string);
    }

    function isValidArchive(a) {
      return a.id is string
        && a.name is string && a.name.size() <= 300
        && a.date is string
        && a.formula is string
        && (a.teamsCount is int || a.teamsCount is float)
        && a.teams is list
        && (!('winnerTeamName' in a) || a.winnerTeamName is string)
        && (!('podium' in a) || a.podium is map || a.podium == null)
        && (!('matches' in a) || a.matches is list || a.matches == null);
    }

    function isValidSave(s) {
      return s.id is string
        && s.name is string && s.name.size() <= 300
        && s.date is string
        && s.formula is string
        && (s.teamsCount is int || s.teamsCount is float)
        && s.teams is list
        && s.matches is list
        && (!('activeTournamentConfig' in s) || s.activeTournamentConfig is map || s.activeTournamentConfig == null)
        && (!('admittedTeamsCount' in s) || s.admittedTeamsCount is int || s.admittedTeamsCount is float || s.admittedTeamsCount == null);
    }

    function isValidMvpVote(v) {
      return v.userId is string
        && v.votedPlayer is string && v.votedPlayer.size() <= 200
        && v.votedAt is string;
    }

    function isValidPost(p) {
      return p.id is string && p.id.size() <= 128
        && p.userId is string && p.userId.size() <= 128
        && p.userName is string && p.userName.size() <= 200
        && (!('userRole' in p) || (p.userRole is string && p.userRole.size() <= 50))
        && (!('content' in p) || (p.content is string && p.content.size() <= 1000))
        && (!('imageUrl' in p) || (p.imageUrl is string && p.imageUrl.size() <= 2000000))
        && (p.createdAt is int || p.createdAt is float)
        && (p.expiresAt is int || p.expiresAt is float);
    }

    function isValidFreePlayMatch(m) {
      return m.id is string && m.id.size() <= 128
        && m.player1AId is string && m.player1AId.size() <= 128
        && m.player1AName is string && m.player1AName.size() <= 300
        && m.player1BId is string && m.player1BId.size() <= 128
        && m.player1BName is string && m.player1BName.size() <= 300
        && m.player2AId is string && m.player2AId.size() <= 128
        && m.player2AName is string && m.player2AName.size() <= 300
        && m.player2BId is string && m.player2BId.size() <= 128
        && m.player2BName is string && m.player2BName.size() <= 300
        && m.createdAt is string && m.createdAt.size() <= 100
        && (m.status == 'pending' || m.status == 'completed')
        && m.date is string && m.date.size() <= 100
        && (!('completedAt' in m) || (m.completedAt is string && m.completedAt.size() <= 100));
    }

    match /freePlayMatches/{matchId} {
      allow read: if true;
      allow create, update: if isValidId(matchId) && isValidFreePlayMatch(request.resource.data);
      allow delete: if isValidId(matchId);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create, update: if isValidId(postId) && isValidPost(request.resource.data);
      allow delete: if isValidId(postId);
    }

    match /teams/{teamId} {
      allow read: if true;
      allow create, update: if isValidId(teamId) && isValidTeam(request.resource.data);
      allow delete: if isValidId(teamId);
    }

    match /matches/{matchId} {
      allow read: if true;
      allow create, update: if isValidId(matchId) && isValidMatch(request.resource.data);
      allow delete: if isValidId(matchId);
    }

    match /notifications/{notificationId} {
      allow read: if true;
      allow create, update: if isValidId(notificationId) && isValidNotification(request.resource.data);
      allow delete: if isValidId(notificationId);
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if isValidId(userId) && isValidUser(request.resource.data);
      allow delete: if isValidId(userId);
    }

    match /registrationRequests/{requestId} {
      allow read: if true;
      allow create, update: if isValidId(requestId) && isValidRegistrationRequest(request.resource.data);
      allow delete: if isValidId(requestId);
    }

    match /archives/{archiveId} {
      allow read: if true;
      allow create, update: if isValidId(archiveId) && isValidArchive(request.resource.data);
      allow delete: if isValidId(archiveId);
    }

    match /saves/{saveId} {
      allow read: if true;
      allow create, update: if isValidId(saveId) && isValidSave(request.resource.data);
      allow delete: if isValidId(saveId);
    }

    match /mvpVotes/{voteId} {
      allow read: if true;
      allow create, update: if voteId is string && voteId.size() <= 128 && isValidMvpVote(request.resource.data);
      allow delete: if voteId is string && voteId.size() <= 128;
    }

    match /config/settings {
      allow read: if true;
      allow write: if true;
    }

    match /config/status {
      allow read: if true;
      allow write: if true;
    }
  }
}
